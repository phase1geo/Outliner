[Desktop Entry]
Name=Outliner
GenericName=Outliner
Comment=Organize your words
Categories=Office;WordProcessor;
Exec=io.github.phase1geo.outliner %f
Icon=io.github.phase1geo.outliner
Terminal=false
Type=Application
MimeType=application/io.github.phase1geo.outliner;
X-GNOME-Gettext-Domain=Outliner
X-GNOME-UsesNotifications=true
Keywords=outline;
Actions=NewDocument;

[Desktop Action NewDocument]
Name=New Document
Exec=io.github.phase1geo.outliner -n
